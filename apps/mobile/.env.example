# ==============================================================
# PECAÊ Mobile — Environment Variables
# Expo public variables must start with EXPO_PUBLIC_
# ==============================================================

# --- API Backend ---
EXPO_PUBLIC_API_URL=http://localhost:3001

# --- Google OAuth ---
# Get from: https://console.cloud.google.com/apis/credentials
# Create an "OAuth 2.0 Client ID" of type "Android" for Android and "iOS" for iOS
EXPO_PUBLIC_GOOGLE_CLIENT_ID=AWAITING_KEY
