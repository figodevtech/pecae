# ============================================================
# PECAÊ API — Environment Variables Template
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or .env to git.
# ============================================================

# --- App ---
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:8081

# --- Database (Supabase) ---
# Pooled connection for the API (PgBouncer — port 6543)
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# Direct connection for migrations (port 5432)
DIRECT_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# --- JWT ---
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_SECURE_RANDOM_SECRET_64_BYTES
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Email (Resend) — Configure after finishing M01 ---
RESEND_API_KEY=re_REPLACE_ME
EMAIL_FROM=noreply@pecae.com.br
EMAIL_FROM_NAME=PECAÊ

# --- App Deep Link ---
# Used in email links pointing back to the mobile app
APP_DEEP_LINK_BASE=pecae://

# --- Seed (development only) ---
ADMIN_SEED_EMAIL=admin@pecae.com.br
ADMIN_SEED_PASSWORD=REPLACE_WITH_STRONG_DEV_PASSWORD

# --- OAuth — Google Sign-In ---
# Step 1: Go to https://console.cloud.google.com/apis/credentials
# Step 2: Create an OAuth 2.0 Client ID (type: Web Application for backend validation)
# Step 3: Add authorized redirect URIs for your Expo app proxy
# Step 4: Paste the Client ID below (the secret is NOT needed for mobile flow)
GOOGLE_CLIENT_ID=AWAITING_KEY

# --- OAuth — Apple Sign-In ---
# Step 1: Go to https://developer.apple.com/ → Certificates, IDs & Profiles
# Step 2: Register an App ID with "Sign In with Apple" capability
# Step 3: Create a Service ID for web validation (optional for mobile)
# The APPLE_CLIENT_ID is your app's bundle ID (e.g., com.pecae.app)
APPLE_CLIENT_ID=AWAITING_KEY

# --- Terms version ---
TERMS_VERSION=1.0.0
