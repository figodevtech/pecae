// ============================================================
// PECAÊ — Prisma Schema
// M01-T01: Identity & Auth Entities
// ============================================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// ENUMS
// ============================================================

/// Defines the role/type of a user account.
enum UserType {
  BUYER
  SELLER
  BOTH
  ADMIN
  MODERATOR
}

/// Lifecycle status of a user account.
enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  BANNED
  DELETED
}

// ============================================================
// MODELS
// ============================================================

/// Core user identity record.
model User {
  id String @id @default(uuid())

  // --- Identity ---
  name  String
  email String @unique @db.VarChar(255)

  // --- Auth ---
  passwordHash String? @map("password_hash") @db.Text
  googleId     String? @unique @map("google_id")
  appleId      String? @unique @map("apple_id")
  phone        String? @unique

  // --- Account state ---
  type   UserType   @default(BUYER)
  status UserStatus @default(PENDING_VERIFICATION)

  // --- Verification flags ---
  emailVerified   Boolean   @default(false) @map("email_verified")
  emailVerifiedAt DateTime? @map("email_verified_at")
  phoneVerified   Boolean   @default(false) @map("phone_verified")
  phoneVerifiedAt DateTime? @map("phone_verified_at")

  // --- Profile ---
  avatar String? @db.Text

  // --- Timestamps & LGPD ---
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")
  originalEmail String?   @map("original_email")

  // --- Relations ---
  refreshTokens            RefreshToken[]
  emailVerificationTokens  EmailVerificationToken[]
  passwordResetTokens      PasswordResetToken[]
  otpCodes                 OtpCode[]
  termsAcceptances         TermsAcceptance[]
  sellerProfile            SellerProfile?
  sellerVerifications      SellerVerification[]
  buyerProfile             BuyerProfile?
  notificationPreferences  NotificationPreferences?
  favorites                Favorite[]
  savedSearches            SavedSearch[]
  reviews                  Review[]
  chatRoomsAsBuyer         ChatRoom[]               @relation("ChatBuyer")
  chatRoomsAsSeller        ChatRoom[]               @relation("ChatSeller")
  chatMessages             ChatMessage[]
  chatReads                ChatRead[]
  notifications            Notification[]

  @@index([email])
  @@index([status])
  @@index([type])
  @@map("users")
}

/// Rotating refresh tokens for session management.
/// Each login/refresh generates a new record; old ones are revoked.
model RefreshToken {
  id String @id @default(uuid())

  userId    String @map("user_id")
  tokenHash String @db.Text @map("token_hash")

  // --- Session context ---
  ip        String  @db.VarChar(45)
  userAgent String? @db.Text @map("user_agent")

  // --- Lifecycle ---
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([userId])
  @@map("refresh_tokens")
}

/// Single-use tokens sent via e-mail for account verification.
model EmailVerificationToken {
  id String @id @default(uuid())

  userId    String @map("user_id")
  tokenHash String @db.Text @map("token_hash")

  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([userId])
  @@map("email_verification_tokens")
}

/// Single-use tokens for password reset flow (1 hour expiry).
model PasswordResetToken {
  id String @id @default(uuid())

  userId    String @map("user_id")
  tokenHash String @db.Text @map("token_hash")

  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([userId])
  @@map("password_reset_tokens")
}

/// OTP codes sent via SMS for phone authentication.
model OtpCode {
  id String @id @default(uuid())

  phone    String @db.VarChar(20)
  codeHash String @db.Text @map("code_hash")
  attempts Int    @default(0)

  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([phone])
  @@map("otp_codes")
}

/// Audit record of user acceptance of Terms, Privacy Policy, and LGPD.
model TermsAcceptance {
  id String @id @default(uuid())

  userId    String @map("user_id")
  version   String @db.VarChar(20)
  ip        String @db.VarChar(45)
  userAgent String @db.Text @map("user_agent")

  acceptedAt DateTime @default(now()) @map("accepted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("terms_acceptances")
}

// ============================================================
// M04 — Automotive Catalog Entities
// ============================================================

enum VehicleSegment {
  HATCH
  SEDAN
  SUV
  PICKUP
  VAN
  TRUCK
  MOTORCYCLE
  OTHER
}

enum FuelType {
  GASOLINE
  ETHANOL
  FLEX
  DIESEL
  ELECTRIC
  HYBRID
}

enum TransmissionType {
  MANUAL
  AUTOMATIC
  CVT
  AUTOMATED
}

/// Fixed list of spare part categories available in a salvage vehicle.
model PartCategory {
  id   String @id @default(uuid())
  name String @db.VarChar(100)
  slug String @unique @db.VarChar(100)
  icon String @db.VarChar(50)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([slug])
  @@map("part_categories")
}

model VehicleBrand {
  id      String  @id @default(uuid())
  name    String  @unique @db.VarChar(100)
  country String? @db.VarChar(100)
  logo    String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  models VehicleModel[]

  @@map("vehicle_brands")
}

model VehicleModel {
  id      String         @id @default(uuid())
  brandId String         @map("brand_id")
  name    String         @db.VarChar(100)
  segment VehicleSegment

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  brand    VehicleBrand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  versions VehicleVersion[]

  @@unique([brandId, name])
  @@index([brandId])
  @@map("vehicle_models")
}

model VehicleVersion {
  id           String           @id @default(uuid())
  modelId      String           @map("model_id")
  name         String           @db.VarChar(100)
  engineCode   String?          @map("engine_code") @db.VarChar(50)
  displacement Decimal?         @db.Decimal(3, 1)
  fuel         FuelType
  transmission TransmissionType

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  model VehicleModel  @relation(fields: [modelId], references: [id], onDelete: Cascade)
  years VehicleYear[]
  vehicles Vehicle[]

  @@index([modelId])
  @@map("vehicle_versions")
}

model VehicleYear {
  id        String @id @default(uuid())
  versionId String @map("version_id")
  yearFab   Int    @map("year_fab")
  yearModel Int    @map("year_model")

  createdAt DateTime @default(now()) @map("created_at")

  version VehicleVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  vehicles Vehicle[]

  @@index([versionId])
  @@map("vehicle_years")
}

// ============================================================
// M03 - Seller Profile Entities
// ============================================================

enum SellerType {
  PF
  PJ
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

model SellerProfile {
  id     String @id @default(uuid())
  userId String @unique @map("user_id")

  storeName   String     @map("store_name") @db.VarChar(100)
  type        SellerType
  cnpj        String?    @db.VarChar(20)
  address     String     @db.VarChar(255)
  city        String     @db.VarChar(100)
  state       String     @db.VarChar(2)
  zipCode     String?    @db.VarChar(10) @map("zip_code")
  lat         Float?
  lng         Float?
  whatsapp    String     @db.VarChar(20)
  phone       String?    @db.VarChar(20)
  openHours   Json?      @map("open_hours")
  logo        String?    @db.Text
  description String?    @db.Text

  isVerified       Boolean @default(false) @map("is_verified")
  showWhatsapp     Boolean @default(false) @map("show_whatsapp")
  responseTimeAvg Int?    @map("response_time_avg")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  stats         SellerStats?
  verifications SellerVerification[]
  listings      Listing[]
  vehicles      Vehicle[]
  reviews       Review[]

  @@index([city, state])
  @@map("seller_profiles")
}

model SellerStats {
  id              String @id @default(uuid())
  sellerProfileId String @unique @map("seller_profile_id")

  activeListings         Int  @default(0) @map("active_listings")
  totalListings          Int  @default(0) @map("total_listings")
  totalSold              Int  @default(0) @map("total_sold")
  avgResponseTimeMinutes Int? @map("avg_response_time_minutes")
  rating                 Float?
  totalReviews           Int  @default(0) @map("total_reviews")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sellerProfile SellerProfile @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)

  @@map("seller_stats")
}

model Review {
  id              String   @id @default(uuid())
  sellerProfileId String   @map("seller_profile_id")
  buyerId         String   @map("buyer_id")
  chatRoomId      String   @unique @map("chat_room_id")
  rating          Int      @db.SmallInt
  comment         String?  @db.Text
  isRemoved       Boolean  @default(false) @map("is_removed")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  sellerProfile SellerProfile @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)
  buyer         User          @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  chatRoom      ChatRoom      @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)

  @@index([sellerProfileId])
  @@map("reviews")
}

model SellerVerification {
  id              String             @id @default(uuid())
  sellerProfileId String             @map("seller_profile_id")
  status          VerificationStatus @default(PENDING)
  documentUrls    Json               @default("[]") @map("document_urls")
  notes           String?            @db.Text
  moderatorId     String?            @map("moderator_id")
  resolvedAt      DateTime?          @map("resolved_at")
  createdAt       DateTime           @default(now()) @map("created_at")

  sellerProfile SellerProfile @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)
  moderator     User?         @relation(fields: [moderatorId], references: [id], onDelete: SetNull)

  @@index([sellerProfileId])
  @@map("seller_verifications")
}

// ============================================================
// M08 - Audit Log
// ============================================================

model AuditLog {
  id          String   @id @default(uuid())
  action      String   @db.VarChar(100)
  entity      String   @db.VarChar(100)
  entityId    String   @map("entity_id")
  actorId     String?  @map("actor_id")
  details     Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([entity, entityId])
  @@index([actorId])
  @@map("audit_logs")
}

// ============================================================
// M04/M05 - Listings (Stub)
// ============================================================

enum ListingStatus {
  PENDING
  PUBLISHED
  SOLD
  EXPIRED
  REJECTED
  DRAFT
}

enum VehicleStatus {
  DRAFT
  PENDING
  ACTIVE
  INACTIVE
  SOLD
}

enum PhotoType {
  EXTERIOR
  INTERIOR
  ENGINE
  DAMAGE
  OTHER
}

model Vehicle {
  id              String        @id @default(uuid())
  sellerId        String        @map("seller_id")
  versionId       String        @map("version_id")
  yearFabId       String        @map("year_fab_id")
  
  // RN03: Complete vehicle data
  availableParts  Json          @default("[]") @map("available_parts")
  plate           String?       @db.VarChar(20)
  color           String        @db.VarChar(50)
  city            String        @db.VarChar(100)
  state           String        @db.VarChar(2)
  lat             Float?
  lng             Float?
  observations    String?       @db.Text
  status          VehicleStatus @default(DRAFT)

  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  seller          SellerProfile  @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  version         VehicleVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  yearFab         VehicleYear    @relation(fields: [yearFabId], references: [id], onDelete: Cascade)
  photos          VehiclePhoto[]
  listing         Listing?

  @@index([sellerId, status])
  @@index([city, state])
  @@index([versionId])
  @@map("vehicles")
}

model VehiclePhoto {
  id        String    @id @default(uuid())
  vehicleId String    @map("vehicle_id")
  url       String    @db.Text
  order     Int       @default(0)
  type      PhotoType @default(EXTERIOR)

  createdAt DateTime  @default(now()) @map("created_at")

  vehicle   Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@map("vehicle_photos")
}

model Listing {
  id              String        @id @default(uuid())
  sellerProfileId String        @map("seller_profile_id")
  vehicleId       String        @unique @map("vehicle_id")
  
  title           String        @db.VarChar(255)
  description     String?       @db.Text
  status          ListingStatus @default(PENDING) // RN14: Default PENDING
  
  // Metrics
  views           Int           @default(0)
  favoritesCount  Int           @default(0) @map("favorites_count")
  
  // Quality & Duplicity (RN10)
  isDuplicate     Boolean       @default(false) @map("is_duplicate")
  duplicateOfId   String?       @map("duplicate_of_id")

  // Lifecycle
  publishedAt     DateTime?     @map("published_at")
  expiresAt       DateTime?     @map("expires_at")
  soldAt          DateTime?     @map("sold_at")
  
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  sellerProfile   SellerProfile @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)
  vehicle         Vehicle       @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  favorites       Favorite[]
  chatRooms       ChatRoom[]

  @@index([sellerProfileId, status])
  @@index([status])
  @@map("listings")
}

// ============================================================
// M02 - Buyer Profile Entities
// ============================================================

model BuyerProfile {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  name      String
  avatar    String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("buyer_profile")
}

model NotificationPreferences {
  id           String   @id @default(uuid())
  userId       String   @unique @map("user_id")
  pushEnabled  Boolean  @default(true) @map("push_enabled")
  emailEnabled Boolean  @default(true) @map("email_enabled")
  inAppEnabled Boolean  @default(true) @map("in_app_enabled")

  pushToken    String?  @map("push_token") @db.Text
  createdAt    DateTime @default(now()) @map("created_at")


  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

/// Representa a "curtida" ou "favorito" de um comprador em um anúncio
model Favorite {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  listingId String   @map("listing_id")
  createdAt DateTime @default(now()) @map("created_at")

  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([userId])
  @@map("favorites")
}

/// Representa uma busca salva pelo comprador, com suporte a alertas
model SavedSearch {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  query       String?  @db.VarChar(255)
  filters     Json     @default("{}")
  alertActive Boolean  @default(false) @map("alert_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("saved_searches")
}

// ============================================================
// M08 - Chat & Negociação Entities
// ============================================================

model ChatRoom {
  id        String   @id @default(uuid())
  buyerId   String   @map("buyer_id")
  sellerId  String   @map("seller_id")
  listingId String   @map("listing_id")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  buyer    User          @relation("ChatBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  seller   User          @relation("ChatSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  listing  Listing       @relation(fields: [listingId], references: [id], onDelete: Cascade)
  messages ChatMessage[]
  reads    ChatRead[]
  review   Review?

  @@unique([buyerId, listingId])
  @@index([sellerId])
  @@index([listingId])
  @@map("chat_rooms")
}

model ChatMessage {
  id        String   @id @default(uuid())
  roomId    String   @map("room_id")
  senderId  String   @map("sender_id")
  content   String   @db.Text
  isDeleted Boolean  @default(false) @map("is_deleted")
  createdAt DateTime @default(now()) @map("created_at")

  room   ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender User     @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([roomId, createdAt])
  @@index([senderId])
  @@map("chat_messages")
}

model ChatRead {
  id         String   @id @default(uuid())
  roomId     String   @map("room_id")
  userId     String   @map("user_id")
  lastReadAt DateTime @default(now()) @map("last_read_at")

  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@map("chat_reads")
}

// ============================================================
// M11 — NOTIFICAÇÕES
// ============================================================

enum NotificationType {
  LISTING_PUBLISHED
  LISTING_REJECTED
  VERIFICATION_APPROVED
  VERIFICATION_REJECTED
  CHAT_NEW_MESSAGE
  SAVED_SEARCH_ALERT
  LISTING_EXPIRING
}

enum NotificationChannel {
  PUSH
  EMAIL
  IN_APP
}

enum NotificationStatus {
  SENT
  FAILED
  SKIPPED
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  body      String
  data      Json?
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs      NotificationLog[]

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

model NotificationLog {
  id             String              @id @default(uuid())
  notificationId String              @map("notification_id")
  channel        NotificationChannel
  status         NotificationStatus
  error          String?             @db.Text
  sentAt         DateTime            @default(now()) @map("sent_at")

  notification   Notification        @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@map("notification_logs")
}

